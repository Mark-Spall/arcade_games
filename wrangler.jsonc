{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "arcade-games-api",
  "main": "worker/src/index.js",
  "compatibility_date": "2026-03-31",
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "SCORES",
      "id": "arcade-scores"
    }
  ]
}
